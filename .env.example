# ===== 后端环境变量 =====

# 运行环境
NODE_ENV=development

# API 服务端口（PM2/Nginx 部署用，Vercel 自动忽略）
PORT=1001

# 管理员令牌（必填）：保护查询/统计/服务管理/WS 接口
# 强制要求长度 >= 32 的强随机令牌，未配置或使用弱默认值将拒绝启动
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# CORS 允许的来源（逗号分隔，生产环境务必改为真实域名）
CORS_ORIGINS=http://localhost:5173

# SQLite 数据库文件路径
# - 本地开发：留空则使用 api/logs.db
# - Vercel 部署：留空会使用 /tmp/logs.db（临时性，冷启动丢数据，仅适合 demo）
# - 生产部署：建议指向持久化卷，如 /opt/logverse/data/logs.db
DB_PATH=

# 种子数据接口开关（仅开发环境开启，生产环境保持 false）
ENABLE_SEED=true

# ===== 前端环境变量（Vite 构建期注入）=====

# 前端 bundle 注入的管理员令牌（须与后端 ADMIN_TOKEN 一致）
# 注意：此令牌会被打包进客户端 bundle，仅适用于内部管理工具场景
# 生产环境强烈建议改造为服务端 BFF 代理管理请求，令牌仅存服务端
VITE_ADMIN_TOKEN=
